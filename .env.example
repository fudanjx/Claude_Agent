# AWS Configuration
# Your AWS profile name from ~/.aws/credentials
AWS_PROFILE=your-aws-profile

# AWS region for Bedrock service
AWS_REGION=us-east-1

# Model Configuration
# Primary model ID (inference profile or model ARN)
MODEL_ID=global.anthropic.claude-sonnet-4-6

# Fallback model ID if primary fails
FALLBACK_MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v1:0

# Optional: Override config.yaml settings with environment variables
# Uncomment and modify as needed

# Agent Settings
# MAX_TOKENS=20000
# TEMPERATURE=1.0
# MAX_ITERATIONS=50
# WORKER_MAX_ITERATIONS=20

# Bedrock Client Settings
# BEDROCK_READ_TIMEOUT=300
# BEDROCK_CONNECT_TIMEOUT=60
# MAX_RETRIES=3
# RETRY_BACKOFF_BASE=2

# Compression Settings
# WORKING_SET_MAX_CHARS=10000
# ROLLING_SUMMARY_MAX_CHARS=20000

# Worker Settings
# WORKER_SCAN_INTERVAL=10

# Skills Configuration
# SKILLS_ENABLED=true
